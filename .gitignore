# Prepack backup of package.json (created by packages/shared/scripts/prepare-publish.ts
# and removed by restore-package-json.ts; only on disk during an in-flight publish).
package.json.bak

# The .keelson/ runtime home governs its own ignores via .keelson/.gitignore —
# it's a generated dogfooding home (SQLite, runs, logs, reseeded starter
# commands/scripts); only the committed maintainer workflows under
# .keelson/workflows/ are tracked.

# Per-run isolation worktrees (now carry an installed node_modules).
.worktrees/

# Editor / IDE
.idea/
.vscode/

# Playwright MCP scratch — screenshots, console logs, snapshots from
# headless verification runs. Local-only; never committed.
.playwright-mcp/

# Local agent tooling — personal Codex config + its auto-generated guidance
# file. Local-only; never committed (the tracked project guidance is CLAUDE.md).
.codex/
AGENTS.md
