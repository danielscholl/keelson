{
  "name": "@keelson/shared",
  "version": "0.1.1",
  "description": "Shared types, zod schemas, and the Rib extension contract for the Keelson local agent harness.",
  "license": "Apache-2.0",
  "author": "Daniel Scholl",
  "homepage": "https://github.com/danielscholl/keelson#readme",
  "bugs": {
    "url": "https://github.com/danielscholl/keelson/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielscholl/keelson.git",
    "directory": "packages/shared"
  },
  "keywords": [
    "keelson",
    "rib",
    "agent",
    "harness",
    "workflow"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./chat": {
      "bun": "./src/chat.ts",
      "types": "./dist/chat.d.ts",
      "default": "./dist/chat.js"
    },
    "./exec": {
      "bun": "./src/exec.ts",
      "types": "./dist/exec.d.ts",
      "default": "./dist/exec.js"
    },
    "./paths": {
      "bun": "./src/paths.ts",
      "types": "./dist/paths.d.ts",
      "default": "./dist/paths.js"
    },
    "./server-state": {
      "bun": "./src/server-state.ts",
      "types": "./dist/server-state.d.ts",
      "default": "./dist/server-state.js"
    },
    "./tools": {
      "bun": "./src/tools.ts",
      "types": "./dist/tools.d.ts",
      "default": "./dist/tools.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "prepack": "bun run build && bun ./scripts/prepare-publish.ts",
    "postpack": "bun ./scripts/restore-package-json.ts"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14"
  },
  "publishConfig": {
    "access": "public"
  }
}
